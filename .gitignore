# Includes common OS files, editor configs, and temporary files

# macOS
.DS_Store

# Windows
Thumbs.db

# Vim swap files
*.swp
*.swo

# Temporary files
*~

# Editor configs
.vscode/
.idea/

# Logs
*.log

# Claude CLI task files
arvad_task_files/
